# Supabase Configuration
# Pegue esses valores em: Settings -> API no seu painel do Supabase
VITE_SUPABASE_URL=https://sua-url-aqui.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Instruções para Vercel:
# 1. No painel da Vercel, vá em Settings -> Environment Variables.
# 2. Adicione VITE_SUPABASE_URL e VITE_SUPABASE_ANON_KEY com os valores acima.
# 3. O deploy será feito automaticamente ao dar 'git push'.
